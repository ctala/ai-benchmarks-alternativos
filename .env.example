# =============================================
# API keys para el benchmark de modelos AI
# =============================================
# Copiar este archivo a .env y completar con tus keys reales.
# .env está en .gitignore → tus keys nunca se versionan.

# --- OpenRouter (obligatorio, acceso a 290+ modelos) ---
# Crear key en: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# --- OpenAI directo (opcional, para GPT-4.1, GPT-5.x) ---
# Crear key en: https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# --- MiniMax directo (opcional, para M2.7 highspeed y multimodal) ---
# Crear key en: https://www.minimaxi.com/user-center/basic-information/interface-key
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.io/v1

# --- Groq (opcional, LPU - super rápido, OpenAI-compatible) ---
# Crear key en: https://console.groq.com/keys
# Ideal para Llama 3.3/4, Mixtral, Qwen, GPT-OSS con tool calling nativo.
# Desbloquea Llama 4 Maverick que falla con tools en OpenRouter.
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1

# --- NVIDIA NIM (opcional, modelos hosted por NVIDIA) ---
# Crear key en: https://build.nvidia.com/ (account > API keys)
# Rate limit free tier: 40 RPM. Modelos típicos: nvidia/nemotron-*, meta/llama-*
NVIDIA_NIM_API_KEY=
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1

# --- Ollama Cloud (opcional, para modelos cloud-only) ---
# Requiere suscripción. Modelos como qwen3.5:397b-cloud, gpt-oss:120b-cloud.
# Crear key en: https://ollama.com/settings/keys
# Los modelos cloud usan tier="cloud_ollama" y provider="ollama_cloud" en config.
OLLAMA_CLOUD_API_KEY=
OLLAMA_CLOUD_BASE_URL=https://ollama.com/v1

# --- Xiaomi MiMo Token Plan (opcional, para MiMo V2.5 / V2.5-Pro) ---
# Suscripción mensual con 8 modelos. OpenAI-compatible.
# Crear cuenta + plan en: https://platform.xiaomimimo.com/
# Modelos: mimo-v2.5-pro, mimo-v2.5, mimo-v2-pro, mimo-v2-omni, mimo-v2.5-tts*
# Off-peak 16-24 UTC = 0.8x consumption (20% off).
XIAOMI_API_KEY=
XIAOMI_BASE_URL=https://token-plan-sgp.xiaomimimo.com/v1

# --- Ollama local (opcional, Ollama corriendo en localhost:11434) ---
# Ideal para DGX Spark u otra GPU con modelos de hasta 128GB.
# Los modelos locales se definen en OLLAMA_MODELS (dict separado) con tier="local".
# Cloud y local conviven: Cloud para modelos 397B+, Local para lo que quepa en tu hardware.
INCLUDE_OLLAMA=false
