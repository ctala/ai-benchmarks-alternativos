  "integration_example_python": "import json, urllib.request\n\nDATA = json.loads(urllib.request.urlopen('https://benchmarks.cristiantala.com/data/models.json').read())\nGUIDE = json.loads(urllib.request.urlopen('https://benchmarks.cristiantala.com/data/agents-decision-guide.json').read())\n\ndef recommend(use_case_id):\n    use_case = next(uc for uc in GUIDE['use_cases'] if uc['id'] == use_case_id)\n    return use_case['top_models']\n\nprint(recommend('coding_n8n_templates'))",
